<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#FF5A5A5A"
                android:centerColor="@color/icon_sensory_background_color"
                android:endColor="#FF303030" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:centerX="0.30"
                android:centerY="0.18"
                android:gradientRadius="90dp"
                android:startColor="#22FFFFFF"
                android:centerColor="#0AF7F7F7"
                android:endColor="#00000000" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:centerX="0.80"
                android:centerY="0.84"
                android:gradientRadius="124dp"
                android:startColor="#28101010"
                android:endColor="#00101010" />
        </shape>
    </item>
</layer-list>
